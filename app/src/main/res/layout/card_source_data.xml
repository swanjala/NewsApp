<?xml version="1.0" encoding="utf-8"?>

<android.support.v7.widget.CardView
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:id="@+id/cl_card_constaints"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="@dimen/card_source_data_layout_layout_height"
    android:elevation="@dimen/card_view_elevation"
    android:layout_marginTop="@dimen/card_source_data_layout_margin_topm">
<android.support.constraint.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <TextView
        android:id="@+id/tv_name"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/card_source_tv_name_layout_height"
        android:layout_marginStart="@dimen/card_source_tv_name_layout_margin_start"
        android:layout_marginLeft="@dimen/card_source_tv_name_layout_margin_left"
        android:layout_marginTop="@dimen/card_source_tv_name_layout_margin_top"
        android:layout_marginEnd="@dimen/card_source_tv_name_layout_margin_end"
        android:layout_marginRight="@dimen/card_source_tv_name_layout_margin_right"
        android:layout_marginBottom="@dimen/card_source_tv_name_layout_margin_bottom"
        android:contentDescription="@string/news_source_name"
        android:textSize="@dimen/card_source_tv_name_text_size"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/tv_description"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.666" />

    <TextView
        android:id="@+id/tv_description"
        android:layout_width="@dimen/card_source_data_tv_description_layout_width"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/card_source_data_tv_description_layout_margin_bottom"
        android:hint="Description"
        android:contentDescription="@string/content_description_show_news_from_source"
        app:layout_constraintBottom_toTopOf="@+id/tv_category"
        app:layout_constraintEnd_toEndOf="@+id/tv_name"
        app:layout_constraintHorizontal_bias="0.003"
        app:layout_constraintStart_toStartOf="@+id/tv_name" />

    <TextView
        android:id="@+id/tv_category"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/card_source_data_tv_category_margin_start"
        android:layout_marginLeft="@dimen/card_source_data_tv_category_margin_left"
        android:layout_marginTop="@dimen/card_source_data_tv_category_margin_top"
        android:layout_marginEnd="@dimen/card_source_data_tv_category_margin_end"
        android:layout_marginRight="@dimen/card_source_data_tv_category_margin_right"
        android:layout_marginBottom="@dimen/card_source_data_tv_category_margin_bottom"
        android:background="@color/colorAccent"
        android:hint="Category"
        android:textStyle="bold"
        android:padding="1dp"
        android:textColor="@color/colorPrimary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/tv_language"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="@+id/tv_description"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0" />

    <TextView
        android:id="@+id/tv_language"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/card_source_data_tv_language_margin_end"
        android:layout_marginRight="@dimen/card_source_data_tv_language_margin_right"
        android:layout_marginBottom="@dimen/card_source_data_tv_language_margin_bottom"
        android:hint="Language"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/tv_category"
        app:layout_constraintEnd_toStartOf="@+id/tv_country"
        app:layout_constraintTop_toTopOf="@+id/tv_category"
        app:layout_constraintVertical_bias="0.0" />

    <TextView
        android:id="@+id/tv_country"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/card_source_data_tv_country_margin_bottom"
        android:hint="Country"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/tv_language"
        app:layout_constraintEnd_toEndOf="@+id/tv_description"
        app:layout_constraintTop_toTopOf="@+id/tv_language"
        app:layout_constraintVertical_bias="0.0" />
</android.support.constraint.ConstraintLayout>
</android.support.v7.widget.CardView>