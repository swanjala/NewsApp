<?xml version="1.0" encoding="utf-8"?>

<android.support.v7.widget.CardView
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:id="@+id/cl_card_category_list"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="@dimen/card_category_list_layout_height"
    android:elevation="@dimen/card_view_elevation"
    android:layout_marginTop="@dimen/card_category_list_layout_margin_top">
    <android.support.constraint.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <TextView
            android:id="@+id/tv_categories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/card_category_margin_start"
            android:layout_marginLeft="@dimen/card_category_margin_left"
            android:layout_marginTop="@dimen/card_category_margin_top"
            android:layout_marginEnd="@dimen/card_category_margin_end"
            android:layout_marginRight="@dimen/card_category_margin_right"
            android:layout_marginBottom="@dimen/card_category_margin_bottom"
            android:contentDescription="@string/category_content_description"
            android:textSize="@dimen/card_category_text_size"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.498"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.328" />

    </android.support.constraint.ConstraintLayout>
</android.support.v7.widget.CardView>